# SundayStage Web — environment template.
# Copy to .env.local for development and fill in real values. Never commit secrets.

# ── Supabase (required) ──────────────────────────────────────────────────────
# Project URL + anon key are public (shipped to the browser). The service-role
# key is server-only and bypasses RLS — keep it out of any NEXT_PUBLIC_* var.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──────────────────────────────────────────────────────────────────────
# Canonical origin used for share links / QR codes (no trailing slash).
NEXT_PUBLIC_BASE_URL=https://stage.sundaysuite.app

# Cookie domain for cross-app SSO sessions (e.g. .sundaysuite.app). Optional in
# local dev — leave blank to scope cookies to localhost.
NEXT_PUBLIC_COOKIE_DOMAIN=

# ── Sunday Account SSO (optional — set when verifying suite identities) ───────
SUNDAY_AUTH_ISSUER=https://account.sundaysuite.app
SUNDAY_AUTH_AUDIENCE=sundaystage
SUNDAY_JWKS_URL=https://account.sundaysuite.app/.well-known/jwks.json

# ── AI subtitles / translation (optional) ────────────────────────────────────
ANTHROPIC_API_KEY=
